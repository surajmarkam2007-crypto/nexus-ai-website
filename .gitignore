# Git Ignore for NEXUS AI Website

# System files
.DS_Store
Thumbs.db
*.log
*.tmp

# Editor files
.vscode/settings.json
.idea/

# Node (if ever used)
node_modules/
package-lock.json

# Backup files
*.bak
*.backup

# Large uncompressed videos (always compress before committing)
# *.mp4  ← DO commit compressed MP4s

# Environment files
.env
.env.local
